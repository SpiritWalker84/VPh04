# PostgreSQL (только внутри сети Docker; на хост не пробрасывается)
POSTGRES_USER=vph04
POSTGRES_PASSWORD=замените_на_надёжный_пароль
POSTGRES_DB=vph04

# Backend / сессия админки (обязательны для контейнера backend)
# SECRET_KEY — случайная строка ≥ 32 символов (подпись cookie сессии).
SECRET_KEY=замените_на_длинную_случайную_строку_32plus
# Вход на /admin/: логин и пароль (≥ 8 символов). Без HTTPS cookie передаётся открытым HTTP — см. README.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=замените_на_надёжный_пароль_админки
# Swagger/OpenAPI: true только для разработки; в обычном подъёме через Compose по умолчанию false
DOCS_ENABLED=false

# Backend: для локального `uvicorn` без Compose:
# DATABASE_URL=postgresql+asyncpg://vph04:пароль@localhost:5432/vph04

# pgAdmin (веб-интерфейс; логин — email)
# Домены .local и часть «служебных» зон pgAdmin отклоняет — используйте обычный вид email.
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=замените_на_надёжный_пароль

# Порты на хосте
# HTTP через Nginx (по умолчанию без TLS — см. README)
NGINX_HTTP_PORT=8080
# pgAdmin
PGADMIN_PORT=5050
